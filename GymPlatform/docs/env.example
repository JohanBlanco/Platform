# Copia a .env y completa los valores opcionales
# cp docs/env.example .env

# --- Neon PostgreSQL (producción / Render) ---
# Org / proyecto (referencia en console.neon.tech):
# NEON_ORG_ID=org-square-resonance-27866607
# NEON_PROJECT_ID=summer-unit-50332044
#
# Connection string Neon → JDBC:
# postgresql://USER:PASS@HOST/neondb?sslmode=require
#   → DB_URL=jdbc:postgresql://HOST/neondb?sslmode=require
DB_URL=
DB_USER=
DB_PASSWORD=
SPRING_PROFILES_ACTIVE=prod
# Primera vez: update. Luego: validate
SPRING_JPA_HIBERNATE_DDL_AUTO=update
APP_JWT_SECRET=
APP_SECRETS_ENCRYPTION_KEY=
APP_CORS_ALLOWED_ORIGINS=http://localhost:5173
APP_PUBLIC_BASE_URL=http://localhost:5173

# Atajo local: bash backend/scripts/run-prod-neon.sh

# GitHub Wiki (opcional — para push automático)
WIKI_PUSH_TOKEN=

# Repositorio en formato owner/repo (se detecta automáticamente con git remote si está vacío)
GITHUB_REPOSITORY=

# Notion (opcional — para sync automático del hub)
# Crear integración en: https://www.notion.so/my-integrations
NOTION_TOKEN=
# ID de la página GymPlatform (de la URL: notion.so/workspace/PAGE_ID?v=...)
NOTION_PAGE_ID=
