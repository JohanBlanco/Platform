{
  "name": "gym-platform-web",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "preview": "vite preview",
    "cy:open": "cypress open",
    "cy:open:prod": "cypress open --config baseUrl=https://gym-platform-cr.vercel.app",
    "cy:run": "cypress run",
    "cy:run:prod": "cypress run --config baseUrl=https://gym-platform-cr.vercel.app --spec cypress/e2e/login.cy.ts,cypress/e2e/smoke-prod.cy.ts,cypress/e2e/role-navigation.cy.ts"
  },
  "dependencies": {
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/sortable": "^10.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "jspdf": "^4.2.1",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-router-dom": "^7.1.1",
    "recharts": "^3.9.2"
  },
  "devDependencies": {
    "@types/react": "^19.0.2",
    "@types/react-dom": "^19.0.2",
    "@vitejs/plugin-react": "^4.3.4",
    "cypress": "^14.5.4",
    "typescript": "~5.7.2",
    "vite": "^6.0.5"
  },
  "allowScripts": {
    "cypress@14.5.4": true
  }
}
